                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                        <Button.Flyout>
                            <Flyout Placement="RightEdgeAlignedTop">
                                <StackPanel Spacing="12" Width="260">
                                    <StackPanel
                                        x:Name="UartDecoderSettingsPanel"
                                        Spacing="10">
                                        <TextBlock
                                            FontSize="14"
                                            FontWeight="SemiBold"
                                            Text="UART" />
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Channel" />
                                            <ComboBox
                                                x:Name="DecoderChannelComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="DecoderChannelComboBox_SelectionChanged" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Baud rate" />
                                            <ComboBox
                                                x:Name="DecoderBaudComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="DecoderBaudComboBox_SelectionChanged" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Data bits" />
                                            <ComboBox
                                                x:Name="DecoderDataBitsComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="DecoderDataBitsComboBox_SelectionChanged" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Stop bits" />
                                            <ComboBox
                                                x:Name="DecoderStopBitsComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="DecoderStopBitsComboBox_SelectionChanged" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Parity" />
                                            <ComboBox
                                                x:Name="DecoderParityComboBox"
                                                Grid.Column="1"
                                                HorizontalAlignment="Stretch"
                                                SelectionChanged="DecoderParityComboBox_SelectionChanged" />
                                        </Grid>
                                        <Grid ColumnSpacing="10">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="88" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock
                                                Grid.Column="0"
                                                VerticalAlignment="Center"
                                                Style="{StaticResource FieldLabelStyle}"
                                                Text="Line color" />
                                            <Grid
                                                x:Name="DecoderColorGrid"
                                                Grid.Column="1"
                                                ColumnSpacing="5"
                                                RowSpacing="5">
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>
                                            </Grid>
                                        </Grid>
                                    </StackPanel>
                                </StackPanel>
                            </Flyout>
                        </Button.Flyout>
                    </Button>
                    <Button
                        x:Name="DecoderAddButton"
                        Grid.Column="2"
                        AutomationProperties.Name="Add decoder"
                        Click="DecoderAddButton_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Add decoder">
                        <FontIcon FontSize="18" Glyph="&#xE710;" />
                    </Button>
                </Grid>
                <TextBlock
                    x:Name="DecoderStatusText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />
                <StackPanel
                    x:Name="DecoderRowsPanel"
                    Spacing="8"
                    Width="340" />
                </StackPanel>

                <StackPanel
                    x:Name="ExpressionSectionPanel"
                    Spacing="12"
                    Visibility="Collapsed">
                    <TextBlock
                        FontSize="16"
                        FontWeight="SemiBold"
                        Text="Expression" />
                </StackPanel>

                <TextBlock
                    x:Name="StatusText"
                    FontSize="14"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="CurrentFileText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />
                <TextBlock
                    x:Name="SignalCountText"
                    FontSize="12"
