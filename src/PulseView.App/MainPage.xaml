<?xml version="1.0" encoding="utf-8" ?>
<Page
    x:Class="PulseView.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="using:PulseView.App.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:PulseView.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Page.Resources>
        <Style
            x:Key="IconButtonStyle"
            BasedOn="{StaticResource DefaultButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="38" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="HorizontalAlignment" Value="Left" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="ToolbarIconButtonStyle"
            BasedOn="{StaticResource DefaultButtonStyle}"
            TargetType="Button">
            <Setter Property="Width" Value="40" />
            <Setter Property="Height" Value="36" />
            <Setter Property="MinWidth" Value="0" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="VerticalAlignment" Value="Center" />
        </Style>
        <Style
            x:Key="FieldLabelStyle"
            TargetType="TextBlock">
            <Setter Property="FontSize" Value="12" />
            <Setter Property="Foreground" Value="{ThemeResource TextFillColorSecondaryBrush}" />
            <Setter Property="TextTrimming" Value="CharacterEllipsis" />
        </Style>
    </Page.Resources>

    <NavigationView
        x:Name="RootNavigationView"
        AlwaysShowHeader="False"
        Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
        CompactPaneLength="56"
        IsBackButtonVisible="Collapsed"
        IsPaneOpen="True"
        IsPaneToggleButtonVisible="True"
        IsSettingsVisible="False"
        OpenPaneLength="220"
        PaneDisplayMode="Left"
        SelectionChanged="RootNavigationView_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                x:Name="MainNavigationItem"
                Content="Main"
                Tag="Main"
                ToolTipService.ToolTip="Main">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE80F;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                x:Name="DecoderNavigationItem"
                Content="Decoder"
                Tag="Decoder"
                ToolTipService.ToolTip="Decoder">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE8D4;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
            <NavigationViewItem
                x:Name="ExpressionNavigationItem"
                Content="Expression"
                Tag="Expression"
                ToolTipService.ToolTip="Expression">
                <NavigationViewItem.Icon>
                    <FontIcon Glyph="&#xE943;" />
                </NavigationViewItem.Icon>
            </NavigationViewItem>
        </NavigationView.MenuItems>

        <Grid Padding="20" ColumnSpacing="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

        <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto">
            <StackPanel Spacing="12">
                <TextBlock
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="PulseView" />
                <TextBlock
                    x:Name="NativeBridgeVersionText"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                <TextBlock
                    x:Name="NativeRenderingVersionText"
                    FontSize="14"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}" />

                <StackPanel
                    x:Name="MainSectionPanel"
                    Spacing="12">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Device" />
                <Grid ColumnSpacing="8" Width="340">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        x:Name="DeviceComboBox"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="DeviceComboBox_SelectionChanged" />
                    <Button
                        x:Name="ScanDeviceButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Scan devices"
                        Click="ScanDeviceButton_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Scan devices">
                        <PathIcon
                            Width="20"
                            Height="20"
                            Data="M11.4142 3.63503C11.6095 3.43977 11.6095 3.12319 11.4142 2.92792L9.29289 0.806603C9.09763 0.611341 8.78104 0.611341 8.58578 0.806603C8.39052 1.00186 8.39052 1.31845 8.58578 1.51371L9.58264 2.51056C7.80518 2.60911 6.05488 3.33754 4.69671 4.6957C1.76776 7.62463 1.76776 12.3734 4.69671 15.3023C4.95359 15.5592 5.2247 15.7937 5.50757 16.0058C5.72852 16.1714 6.04191 16.1266 6.20756 15.9057C6.3732 15.6847 6.32838 15.3713 6.10743 15.2057C5.86235 15.0219 5.6271 14.8185 5.40382 14.5952C2.8654 12.0568 2.8654 7.94121 5.40382 5.40281C6.68997 4.11666 8.38002 3.48223 10.0664 3.49934C10.0915 3.49959 10.1162 3.49799 10.1404 3.49466L8.58578 5.04924C8.39052 5.24451 8.39052 5.56109 8.58578 5.75635C8.78104 5.95161 9.09763 5.95161 9.29289 5.75635L11.4142 3.63503ZM8.58578 16.363C8.39052 16.5582 8.39052 16.8748 8.58578 17.0701L10.7071 19.1914C10.9024 19.3866 11.219 19.3866 11.4142 19.1914C11.6095 18.9961 11.6095 18.6795 11.4142 18.4843L10.4174 17.4874C12.1948 17.3889 13.9451 16.6605 15.3033 15.3023C18.2322 12.3734 18.2322 7.62462 15.3033 4.69569C15.0464 4.43881 14.7753 4.20428 14.4924 3.99221C14.2715 3.82656 13.9581 3.87139 13.7924 4.09233C13.6268 4.31327 13.6716 4.62667 13.8926 4.79231C14.1377 4.97606 14.3729 5.17952 14.5962 5.40279C17.1346 7.9412 17.1346 12.0568 14.5962 14.5952C13.31 15.8813 11.62 16.5158 9.9336 16.4987C9.90849 16.4984 9.88379 16.5 9.85963 16.5033L11.4142 14.9487C11.6095 14.7535 11.6095 14.4369 11.4142 14.2416C11.219 14.0464 10.9024 14.0464 10.7071 14.2416L8.58578 16.363Z"
                            Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                    </Button>
                    <Button
                        x:Name="ConnectDeviceButton"
                        Grid.Column="2"
                        AutomationProperties.Name="Load selected device"
                        Click="ConnectDeviceButton_Click"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Load selected device">
                        <Grid Width="20" Height="20">
                            <Ellipse
                                x:Name="ConnectDeviceIdleIcon"
                                Width="14"
                                Height="14"
                                Fill="Transparent"
                                HorizontalAlignment="Center"
                                Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                StrokeThickness="2"
                                VerticalAlignment="Center" />
                            <Ellipse
                                x:Name="ConnectDeviceLoadedIcon"
                                Width="14"
                                Height="14"
                                Fill="#D13438"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Visibility="Collapsed" />
                        </Grid>
                    </Button>
                </Grid>
                <TextBlock
                    x:Name="DeviceStatusText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />

                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Acquisition" />
                <Grid ColumnSpacing="8" RowSpacing="8" Width="340">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0" Spacing="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Digital channels" />
                            <ComboBox
                                x:Name="ChannelCountComboBox"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="ChannelCountComboBox_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Spacing="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Sample rate" />
                            <ComboBox
                                x:Name="SampleRateComboBox"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="SampleRateComboBox_SelectionChanged" />
                        </StackPanel>
                        <StackPanel Grid.Column="2" Spacing="4">
                            <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Sample count" />
                            <ComboBox
                                x:Name="SampleCountComboBox"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="SampleCountComboBox_SelectionChanged" />
                        </StackPanel>
                    </Grid>

                    <StackPanel Grid.Row="1" Spacing="4">
                        <TextBlock Style="{StaticResource FieldLabelStyle}" Text="Trigger" />
                        <Grid ColumnSpacing="6">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="176" />
                                <ColumnDefinition Width="70" />
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="38" />
                            </Grid.ColumnDefinitions>
                            <ComboBox
                                x:Name="TriggerEdgeComboBox"
                                Grid.Column="0"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="TriggerEdgeComboBox_SelectionChanged" />
                            <ComboBox
                                x:Name="TriggerChannelComboBox"
                                Grid.Column="1"
                                HorizontalAlignment="Stretch"
                                SelectionChanged="TriggerChannelComboBox_SelectionChanged" />
                            <Button
                                x:Name="AcquisitionButton"
                                Grid.Column="2"
                                AutomationProperties.Name="Toggle acquisition"
                                Click="AcquisitionButton_Click"
                                Style="{StaticResource IconButtonStyle}">
                                <Grid Width="20" Height="20">
                                    <Grid
                                        x:Name="AcquisitionPauseIcon"
                                        Width="20"
                                        Height="20"
                                        Visibility="Visible">
                                        <Line
                                            X1="7"
                                            X2="7"
                                            Y1="4"
                                            Y2="16"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="2.1" />
                                        <Line
                                            X1="13"
                                            X2="13"
                                            Y1="4"
                                            Y2="16"
                                            Stroke="{ThemeResource TextFillColorPrimaryBrush}"
                                            StrokeThickness="2.1" />
                                    </Grid>
                                    <Viewbox
                                        x:Name="AcquisitionPlayIcon"
                                        Width="20"
                                        Height="20"
                                        Visibility="Collapsed">
                                        <Canvas Width="20" Height="20">
                                            <Path
                                                Data="M17.2221 8.68458C18.2586 9.25438 18.2586 10.7437 17.2221 11.3135L7.22259 16.8105C6.22292 17.36 5 16.6367 5 15.496L5 4.50214C5 3.36137 6.22292 2.63812 7.22259 3.18766L17.2221 8.68458Z"
                                                Fill="#0078D4" />
                                        </Canvas>
                                    </Viewbox>
                                </Grid>
                            </Button>
                            <Button
                                x:Name="OpenFileButton"
                                Grid.Column="3"
                                AutomationProperties.Name="Open capture"
                                Click="OpenFileButton_Click"
                                Style="{StaticResource IconButtonStyle}"
                                ToolTipService.ToolTip="Open capture">
                                <PathIcon
                                    Width="20"
                                    Height="20"
                                    Data="M3.00026 5.5V12.1041L4.50091 9.50488C5.03681 8.57668 6.02719 8.00488 7.09898 8.00488L15.0003 8.00488V7.5C15.0003 6.67157 14.3287 6 13.5003 6H9.50026C9.36765 6 9.24047 5.94732 9.1467 5.85355L7.4396 4.14645C7.34583 4.05268 7.21865 4 7.08604 4H4.50026C3.67183 4 3.00026 4.67157 3.00026 5.5ZM4.28361 15.9845C4.35498 15.9947 4.42844 16 4.50373 16H13.9012C14.6157 16 15.276 15.6188 15.6332 15L17.7955 11.2549C18.3728 10.2549 17.6511 9.00488 16.4964 9.00488L7.09898 9.00488C6.38445 9.00488 5.7242 9.38608 5.36694 10.0049L3.20469 13.75C2.78223 14.4817 3.0553 15.3473 3.68462 15.7591C3.86197 15.8742 4.06517 15.9529 4.28361 15.9845ZM2.00026 14.4607V5.5C2.00026 4.11929 3.11955 3 4.50026 3H7.08604C7.48387 3 7.8654 3.15804 8.1467 3.43934L9.70736 5H13.5003C14.881 5 16.0003 6.11929 16.0003 7.5V8.00488H16.4964C18.4209 8.00488 19.6237 10.0882 18.6615 11.7549L16.4992 15.5C15.9633 16.4282 14.973 17 13.9012 17H4.50026C4.4378 17 4.37588 16.9977 4.31457 16.9932C3.75344 16.9527 3.26124 16.7329 2.87665 16.4011C2.36561 15.9642 2.03283 15.3249 2.00252 14.6073C2.00031 14.5586 1.99955 14.5097 2.00026 14.4607Z"
                                    Foreground="{ThemeResource TextFillColorPrimaryBrush}" />
                            </Button>
                        </Grid>
                    </StackPanel>
                </Grid>
                <TextBlock
                    x:Name="CaptureSettingsText"
                    FontSize="12"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    TextWrapping="WrapWholeWords" />
                </StackPanel>

                <StackPanel
                    x:Name="DecoderSectionPanel"
                    Spacing="12"
                    Visibility="Collapsed">
                <TextBlock
                    FontSize="16"
                    FontWeight="SemiBold"
                    Text="Decoder" />
                <Grid ColumnSpacing="8" Width="340">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <ComboBox
                        x:Name="DecoderComboBox"
                        Grid.Column="0"
                        HorizontalAlignment="Stretch"
                        SelectionChanged="DecoderComboBox_SelectionChanged" />
                    <Button
                        x:Name="DecoderSettingsButton"
                        Grid.Column="1"
                        AutomationProperties.Name="Decoder settings"
                        Style="{StaticResource IconButtonStyle}"
                        ToolTipService.ToolTip="Decoder settings">
